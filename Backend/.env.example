# Database Configuration
DATASOURCE_URL=jdbc:postgresql://your-host:your-port/database-name?user=username&password=password&sslmode=require&channelBinding=require&currentSchema=public

# JWT Configuration
JWT_SIGNER_KEY=your-secret-key-here-min-64-characters
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000
