# Database Configuration
# IMPORTANT: Copy this to .env and fill in your actual values
# NEVER commit .env file to version control
DATASOURCE_URL=jdbc:postgresql://your-host:5432/your-database?sslmode=require&currentSchema=public
DATASOURCE_USERNAME=your-username
DATASOURCE_PASSWORD=your-password

# JWT Keys
# You can load from files or set directly as environment variables
# Option 1: Set directly (for small environments)
JWT_PRIVATE_KEY=your-private-key-here
JWT_PUBLIC_KEY=your-public-key-here

# Option 2: Or use file paths (recommended for production)
# JWT_PRIVATE_KEY_FILE=/path/to/private_key.txt
# JWT_PUBLIC_KEY_FILE=/path/to/public_key.txt

# JWT Token Duration (in seconds)
JWT_VALID_DURATION=3600
JWT_REFRESHABLE_DURATION=36000
